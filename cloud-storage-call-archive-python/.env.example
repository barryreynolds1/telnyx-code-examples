TELNYX_API_KEY=your_telnyx_api_key_here
BUCKET_NAME=call-archive
# Telnyx Cloud Storage region: us-central-1 | us-east-1 | us-west-1 | eu-central-1
TELNYX_STORAGE_REGION=us-central-1
HOST=127.0.0.1
PORT=5000
# Required to verify inbound webhook signatures (Portal > Keys & Credentials > Public Key)
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here
